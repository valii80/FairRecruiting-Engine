<Window x:Class="FairRecruitingEngine.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fair Recruiting Engine"
        Height="900"
        Width="1250"
        Background="#121212"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="20">

        <!-- ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="200"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*" MinHeight="250"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <Grid Grid.Row="0" Margin="0,0,0,25">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Titel -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Fair Recruiting Engine"
                           Foreground="White"
                           FontSize="32"
                           FontWeight="Bold"/>
                <TextBlock Text="Lokale KI-Analyse für faires Recruiting"
                           Foreground="#AB8DFF"
                           FontSize="14"
                           FontWeight="SemiBold"/>
            </StackPanel>

            <!-- Datei Laden -->
            <Button Grid.Column="1"
                    Command="{Binding LoadFileCommand}"
                    Content="📂 Datei laden"
                    Width="140"
                    Height="45"
                    Background="#2A2A2A"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderBrush="#444444"
                    VerticalAlignment="Bottom"/>

            <!-- Modell Auswahl -->
            <StackPanel Grid.Column="3"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Right">

                <TextBlock Text="KI-MODELL AUSWÄHLEN ↴"
                           Foreground="#888888"
                           FontSize="10"
                           FontWeight="Bold"
                           HorizontalAlignment="Right"
                           Margin="0,0,0,5"/>

                <ComboBox Width="360"
                          MinHeight="42"
                          Padding="8,6"
                          MaxDropDownHeight="120"
                          ItemsSource="{Binding Models}"
                          SelectedItem="{Binding SelectedModelItem}"
                          Background="#1E1E1E"
                          Foreground="White"
                          BorderBrush="#AB8DFF">

                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding StatusIcon}"
                                           Foreground="{Binding StatusColor}"
                                           FontSize="14"
                                           VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding DisplayColor}"
                                               FontSize="13"/>
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="11"
                                               Foreground="#AAAAAA"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>

                </ComboBox>
            </StackPanel>

        </Grid>

        <!-- ================= INPUT + SCREENSHOT ================= -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- Textbereich -->
            <TextBox Grid.Column="0"
                     Text="{Binding JobDescription, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Background="#1E1E1E"
                     Foreground="White"
                     BorderBrush="#333333"
                     Padding="15,12"
                     FontSize="16"
                     CaretBrush="White"/>

            <!-- Screenshot Bereich -->
            <Border Grid.Column="2"
                    Background="#0A0A0A"
                    BorderBrush="#AB8DFF"
                    BorderThickness="2"
                    CornerRadius="10">

                <Grid>

                    <!-- Platzhalter -->
                    <TextBlock Text="SCREENSHOT BEREICH"
                               Foreground="Gray"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <!-- Bild -->
                    <Image Source="{Binding AttachedImageSource}"
                           Stretch="Uniform"
                           Margin="10"/>

                    <!-- Aktiver Screenshot Badge -->
                    <Border VerticalAlignment="Top"
                            HorizontalAlignment="Right"
                            Background="#AB8DFF"
                            Padding="8,3"
                            CornerRadius="0,8,0,8"
                            Visibility="{Binding HasImage, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="AKTIVER SCREENSHOT"
                                   Foreground="White"
                                   FontSize="10"
                                   FontWeight="Bold"/>
                    </Border>

                    <!-- Bildanalyse Hinweis (IMMER sichtbar für Test) -->
                    <StackPanel VerticalAlignment="Bottom"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,12">

                        <TextBlock Text="⚠️ BILD-ANALYSE"
                                   Foreground="#E04A00"
                                   FontWeight="Bold"
                                   FontSize="12"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Screenshot: Win + Umschalt + S"
                                   Foreground="Gray"
                                   FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                </Grid>
            </Border>

        </Grid>

        <!-- ================= SPLITTER ================= -->
        <GridSplitter Grid.Row="2"
              Height="15"
              Margin="0,15"
              Background="Transparent"
              ResizeDirection="Rows"
              ResizeBehavior="PreviousAndNext"
              Cursor="SizeNS"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center">

            <GridSplitter.Template>
                <ControlTemplate TargetType="GridSplitter">
                    <Border Background="Transparent">
                        <Border Height="3"
                        Background="#E04A00"
                        VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </GridSplitter.Template>

        </GridSplitter>

        <!-- ================= ANALYSE ================= -->
        <Grid Grid.Row="3">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Buttons -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>

                <Button Command="{Binding ResetAppCommand}"
                        Content="↻ Alles leeren"
                        Height="50"
                        Background="#2A2A2A"
                        Foreground="White"
                        FontWeight="Bold"/>

                <Button Grid.Column="1"
                        Command="{Binding TestOllamaCommand}"
                        Content="🚀 KI-ANALYSE STARTEN"
                        Margin="15,0,0,0"
                        Height="50"
                        Background="#AB8DFF"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="20"/>

                <Button Grid.Column="2"
                        Content="🌍 Übersetzen"
                        Margin="15,0,0,0"
                        Height="50"
                        Background="#2A2A2A"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="TranslateButton_Click"/>
            </Grid>

            <!-- Ergebnis -->
            <Border Grid.Row="1"
                    Background="#0F0F0F"
                    BorderBrush="#333333"
                    BorderThickness="1"
                    CornerRadius="10">

                <TextBox Text="{Binding StatusMessage}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="Transparent"
                         Foreground="White"
                         Padding="15,12"
                         FontSize="16"
                         BorderThickness="0"/>
            </Border>

        </Grid>

    </Grid>
</Window>